{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "TGWL Dev Server (serve)",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "npx", "serve", ".", "--listen", "3000", "--no-clipboard"],
      "port": 3000
    },
    {
      "name": "TGWL Dev Server (Python)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    }
  ]
}
